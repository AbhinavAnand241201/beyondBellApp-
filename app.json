{
  "expo": {
    "name": "BeyondBell Circle",
    "slug": "beyondbell-circle",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "beyondbell",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F7F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beyondbell.circle"
    },
    "android": {
      "package": "com.beyondbell.circle",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5A400"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "BeyondBell needs access to your photos so you can attach an image to a post.",
          "cameraPermission": "BeyondBell needs camera access so you can add a photo to a post."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "38a356c8-5488-4799-86f3-064cb925aa38"
      }
    }
  }
}
