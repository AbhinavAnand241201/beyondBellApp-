# Supabase — the only secrets the mobile app needs (anon key is public; RLS guards data).
# Mirror these from the web app's .env.local (NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: base URL of the deployed Next.js API (or future Supabase Edge Functions)
# used by Path B server logic (AI tools, post/DM tier checks). Leave blank to use
# direct-Supabase fallbacks where RLS permits.
EXPO_PUBLIC_API_BASE_URL=

# OAuth redirect base (deep link). Defaults to the app scheme when blank.
EXPO_PUBLIC_SITE_URL=

# Razorpay PUBLISHABLE key id (rzp_...). Safe client-side. The secret stays server-side.
EXPO_PUBLIC_RAZORPAY_KEY_ID=
